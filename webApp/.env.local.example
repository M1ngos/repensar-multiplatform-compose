# ═════════════════════════════════════════════════════════════════════════════
# FRONTEND ENVIRONMENT — webApp/.env.local
# Copy this file to .env.local and fill in your values.
# .env.local is never committed to git.
# ═════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# HOW THE FRONTEND TALKS TO THE BACKEND
# ─────────────────────────────────────────────────────────────────────────────
#
# The architecture uses a REVERSE PROXY built into Next.js.
# Instead of the browser calling the FastAPI backend directly, it calls the
# Next.js server, which forwards (proxies) the request to the backend and
# returns the response. This means:
#
#   Browser (any device/IP)
#     │
#     │  POST http://<nextjs-host>:3000/auth/login   ← always same host
#     ▼
#   Next.js server (next.config.ts rewrites)
#     │
#     │  POST http://127.0.0.1:8000/auth/login       ← internal, server-to-server
#     ▼
#   FastAPI backend
#
# Benefits:
#   • Works on any IP / hostname — no hardcoded addresses in the browser bundle.
#   • When you run Next.js with --hostname 0.0.0.0, every device on your LAN
#     can access the app at http://<your-machine-ip>:3000, and all API calls
#     route correctly through the proxy without any extra configuration.
#   • The backend address (127.0.0.1:8000) is a server-side secret — it never
#     reaches the browser.
#
# The proxied route prefixes are defined in next.config.ts:
#   /auth, /users, /volunteers, /projects, /tasks, /resources, /reports,
#   /analytics, /gamification, /blog, /files, /uploads, /search, /sync,
#   /notifications, /newsletter, /contact, /api/v1
#
# ─────────────────────────────────────────────────────────────────────────────

# NEXT_PUBLIC_API_URL
#   The base URL the browser uses to prefix all API calls.
#   Baked into the client-side JavaScript bundle at build/dev startup.
#
#   ┌─ LEAVE EMPTY (recommended) ──────────────────────────────────────────────
#   │   NEXT_PUBLIC_API_URL=
#   │
#   │   Empty string → the API client uses relative URLs (e.g. /auth/login).
#   │   The browser resolves them against the page origin (e.g. http://192.168.1.5:3000).
#   │   Next.js sees the request and applies the rewrites in next.config.ts,
#   │   forwarding it to the backend at BACKEND_URL.
#   │   This is the standard setup and works everywhere.
#   │
#   └─ SET TO A FULL URL (non-proxied / advanced) ──────────────────────────────
#       NEXT_PUBLIC_API_URL=http://192.168.1.5:8000
#
#       Use this ONLY when you intentionally want the browser to bypass
#       Next.js and call the backend directly (e.g. the backend is on a
#       separate host with its own public address and CORS configured).
#       Requires the backend to be reachable by the browser, not just by
#       the Next.js server.
#
NEXT_PUBLIC_API_URL=

# BACKEND_URL
#   The address the Next.js SERVER uses to forward proxied requests.
#   This is a server-side-only variable (no NEXT_PUBLIC_ prefix) — it is
#   never sent to the browser.
#
#   Set this to wherever the FastAPI process is listening FROM THE PERSPECTIVE
#   OF THE MACHINE RUNNING NEXT.JS — not the browser's perspective.
#
#   Examples:
#     Same machine:        http://127.0.0.1:8000   (default)
#     Docker container:    http://backend:8000      (service name in docker-compose)
#     Remote server:       http://api.example.com  (different host)
#
#   Change the port if you started FastAPI on a different port.
#
BACKEND_URL=http://127.0.0.1:8000

# ─────────────────────────────────────────────────────────────────────────────
# GOOGLE OAUTH
# ─────────────────────────────────────────────────────────────────────────────
# Google Sign-In is handled ENTIRELY by the FastAPI backend.
# These variables belong in the backend's .env, NOT here.
# The frontend only calls /auth/google/login (proxied to the backend),
# which redirects the user to Google. No client secrets on the frontend.
#
# Backend variables to set (in repensar-multiplatform-backend/.env):
#   GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
#   GOOGLE_CLIENT_SECRET=your-client-secret
#   GOOGLE_REDIRECT_URI=http://<your-host>:8000/auth/google/callback
#
# For setup instructions see google-signin.md in the project root.
