# ═════════════════════════════════════════════════════════════════════════════
# FRONTEND ENVIRONMENT — Vercel production
# Reference this file when setting environment variables in the Vercel dashboard.
# Do NOT copy this file to .env.production — Vercel reads env vars from its UI.
# ═════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# HOW THE PROXY WORKS IN PRODUCTION (same as local dev, different hosts)
# ─────────────────────────────────────────────────────────────────────────────
#
#   User's Browser (any IP)
#     │
#     │  POST https://your-app.vercel.app/auth/login   ← relative URL
#     ▼
#   Vercel (runs Next.js server-side)
#     │  next.config.ts rewrites match /auth/:path*
#     │
#     │  POST https://repensar-api.up.railway.app/auth/login   ← server-to-server
#     ▼
#   Railway (FastAPI backend)
#
# Key consequences:
#   • NEXT_PUBLIC_API_URL must be EMPTY — the browser uses relative URLs,
#     which Vercel's Next.js server intercepts and proxies to Railway.
#   • BACKEND_URL must point to the Railway public domain — this is the
#     server-side target for the proxy rewrites in next.config.ts.
#   • The Railway URL is NEVER sent to the user's browser.
#   • CORS on Railway only needs to allow the Vercel domain, not user IPs.
#   • Do NOT add rewrites to vercel.json — they are already in next.config.ts.
#
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────
# API BASE URL — MUST STAY EMPTY IN PRODUCTION
# ─────────────────────────────────────────────────────────────────────────────
#
# Empty string → lib/api/client.ts and lib/api/files.ts use relative URLs
# (e.g. /auth/login, /users/me). The browser resolves these against the
# Vercel domain. Vercel's Next.js server matches them via rewrites in
# next.config.ts and forwards the request to Railway (BACKEND_URL).
#
# DO NOT set this to the Railway URL — that would bypass the proxy,
# expose the Railway domain to the browser, and break CORS.
#
# Vercel env var:  NEXT_PUBLIC_API_URL
# Value:           (leave blank — empty string)
#
NEXT_PUBLIC_API_URL=

# ─────────────────────────────────────────────────────────────────────────────
# BACKEND PROXY TARGET — Railway public domain
# ─────────────────────────────────────────────────────────────────────────────
#
# The URL the Next.js SERVER uses when forwarding proxied requests.
# This is server-side only (no NEXT_PUBLIC_ prefix) — never reaches the browser.
#
# Set this to the Railway public domain assigned to your backend service.
# Format: https://<service-name>.up.railway.app
#         or your custom domain if you configured one in Railway.
#
# Where to find it:
#   Railway dashboard → your project → your service → Settings → Networking
#   → "Public Networking" → copy the generated domain.
#
# Vercel env var:  BACKEND_URL
# Value:           https://repensar-api.up.railway.app   ← replace with yours
#
BACKEND_URL=https://repensar-api.up.railway.app

# ─────────────────────────────────────────────────────────────────────────────
# I18NEXUS TRANSLATIONS API KEY
# ─────────────────────────────────────────────────────────────────────────────
#
# Required for the default build command: `pnpm build`
# which expands to: `i18nexus pull && next build`
#
# The `i18nexus pull` step downloads the latest translations from i18nexus
# before building. Without this key the build will fail with an auth error.
#
# Where to find it:
#   i18nexus dashboard → your project → API Keys → copy the export key.
#
# Alternative — skip i18nexus entirely:
#   Override the Build Command in the Vercel dashboard to:
#     pnpm next build
#   This skips the translation pull and uses whatever messages/*.json files
#   are already committed to the repo. Useful if you manage translations
#   manually or do not use i18nexus.
#
# Vercel env var:  I18NEXUS_API_KEY
# Value:           your-i18nexus-api-key
#
I18NEXUS_API_KEY=your-i18nexus-api-key
